OPENAI_API_KEY=your_key_here
ALLOWED_ORIGIN=https://your-deployed-domain.example.com
PORT=3000

# Cloud Storage bucket for completed participant submissions (production).
# No credentials go here — auth is via Application Default Credentials /
# the Cloud Run runtime service account, never a key file or env var.
GCS_SUBMISSIONS_BUCKET=researcher-ai-survey-data-tnl22

# Local development ONLY. When "true", submissions are appended to
# data/submissions.jsonl instead of Cloud Storage, and GCS_SUBMISSIONS_BUCKET
# is not required. Must be unset/false in production (Cloud Run).
USE_LOCAL_SUBMISSION_FILE=false

# ===================== TEST MODE (DEV/QA ONLY — NOT PART OF NORMAL PARTICIPANT FLOW) =====================
# Gates ?test=1 URL overrides (see DEPLOYMENT.md "Test mode" section). A URL
# param alone can NEVER enable test mode — this server-side env var is the
# sole authority. Disabled by default. Set to "false" (or remove this line)
# before real participant recruitment.
ENABLE_TEST_MODE=false

# ===================== ADMIN BULK EXPORT (RESEARCHER USE ONLY) =====================
# Shared secret required in the X-Admin-Key header to call
# GET /api/admin/export-submissions.json and GET /api/admin/export-submissions.csv
# (these read ALL accumulated participant/test records from backend storage —
# separate from the per-session Ctrl+Shift+E browser export). Never sent to
# or referenced by any frontend file, and never accepted via a query string.
# If unset, both routes always return 401. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_EXPORT_KEY=
